# Copy this file to .env and fill in your values.
# On Coolify, set these as environment variables instead of committing .env.

# LLM provider to use: "claude" | "groq" | "openai"
LLM_PROVIDER=groq

# Anthropic / Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
